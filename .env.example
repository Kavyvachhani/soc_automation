# ─── AWS Credentials ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Get these from: GitHub → Settings → Secrets → Actions (they are already stored there).

AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE
AWS_DEFAULT_REGION=us-east-1

# ─── S3 Bucket ────────────────────────────────────────────────────────────────
S3_BUCKET=attest-vault-669167971016

# ─── GitHub (for dispatching workflow events) ─────────────────────────────────
PROJECT_GITHUB_TOKEN=YOUR_GITHUB_PAT_HERE
PROJECT_GITHUB_ORG=Kavyvachhani
GITHUB_REPO=soc_automation

# ─── Anthropic (for AI-powered offer letter extraction) ───────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
